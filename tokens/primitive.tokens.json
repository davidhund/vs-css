{
	"$schema": "https://tokens.design/schema/draft-2024-12/schema.json",
	"color": {
		"neutral": {
			"0": { "$type": "color", "$value": "#ffffff" },
			"100": { "$type": "color", "$value": "#f5f5f5" },
			"200": { "$type": "color", "$value": "#e8e8e8" },
			"300": { "$type": "color", "$value": "#d0d0d0" },
			"400": { "$type": "color", "$value": "#b8b8b8" },
			"500": { "$type": "color", "$value": "#a0a0a0" },
			"600": { "$type": "color", "$value": "#808080" },
			"700": { "$type": "color", "$value": "#525252" },
			"800": { "$type": "color", "$value": "#2d2d2d" },
			"900": { "$type": "color", "$value": "#1a1a1a" }
		},
		"blue": {
			"50": { "$type": "color", "$value": "#f0f7ff" },
			"500": { "$type": "color", "$value": "#0066ff" },
			"700": { "$type": "color", "$value": "#0052cc" }
		},
		"green": {
			"500": { "$type": "color", "$value": "#22a551" },
			"700": { "$type": "color", "$value": "#1a7f3f" }
		},
		"red": {
			"500": { "$type": "color", "$value": "#d92d20" },
			"700": { "$type": "color", "$value": "#a91f13" }
		}
	},
	"space": {
		"1": { "$type": "dimension", "$value": "4px" },
		"2": { "$type": "dimension", "$value": "8px" },
		"3": { "$type": "dimension", "$value": "12px" },
		"4": { "$type": "dimension", "$value": "16px" },
		"6": { "$type": "dimension", "$value": "24px" },
		"8": { "$type": "dimension", "$value": "32px" },
		"12": { "$type": "dimension", "$value": "48px" },
		"16": { "$type": "dimension", "$value": "64px" }
	},
	"font": {
		"family": {
			"sans": {
				"$type": "fontFamily",
				"$value": "system-ui, -apple-system, sans-serif"
			},
			"mono": {
				"$type": "fontFamily",
				"$value": "'Monaco', 'Courier New', monospace"
			},
			"serif": {
				"$type": "fontFamily",
				"$value": "Georgia, serif"
			}
		},
		"size": {
			"sm": { "$type": "dimension", "$value": "0.875rem" },
			"base": { "$type": "dimension", "$value": "1rem" },
			"lg": { "$type": "dimension", "$value": "1.125rem" },
			"xl": { "$type": "dimension", "$value": "1.25rem" },
			"2xl": { "$type": "dimension", "$value": "1.5rem" },
			"3xl": { "$type": "dimension", "$value": "1.875rem" },
			"4xl": { "$type": "dimension", "$value": "2.25rem" }
		},
		"weight": {
			"regular": { "$type": "fontWeight", "$value": "400" },
			"medium": { "$type": "fontWeight", "$value": "500" },
			"bold": { "$type": "fontWeight", "$value": "700" }
		},
		"line-height": {
			"tight": { "$type": "lineHeight", "$value": "1.2" },
			"base": { "$type": "lineHeight", "$value": "1.5" },
			"loose": { "$type": "lineHeight", "$value": "1.75" }
		}
	},
	"radius": {
		"sm": { "$type": "dimension", "$value": "4px" },
		"md": { "$type": "dimension", "$value": "8px" },
		"lg": { "$type": "dimension", "$value": "12px" },
		"full": { "$type": "dimension", "$value": "9999px" }
	},
	"border": {
		"1": { "$type": "dimension", "$value": "1px" },
		"2": { "$type": "dimension", "$value": "2px" }
	}
}
